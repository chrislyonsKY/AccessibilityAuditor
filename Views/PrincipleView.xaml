<UserControl x:Class="AccessibilityAuditor.Views.PrincipleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="clr-namespace:AccessibilityAuditor.Views.Converters"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="320">

    <UserControl.Resources>
        <converters:SeverityToIconConverter x:Key="SeverityToIcon"/>
        <converters:SeverityToColorConverter x:Key="SeverityToColor"/>
        <converters:ColorInfoToBrushConverter x:Key="ColorToBrush"/>
        <converters:HexToBrushConverter x:Key="HexToBrush"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Counts header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8,8,8,4"
                    AutomationProperties.Name="{Binding PrincipleLabel}">
            <TextBlock Text="{Binding PrincipleLabel}" FontWeight="Bold" FontSize="13" Margin="0,0,12,0"/>
            <TextBlock Foreground="#E04343"
                       AutomationProperties.Name="{Binding FailCount, StringFormat='{}{0} failures', Mode=OneWay}">
                <Run Text="{Binding FailCount, Mode=OneWay}"/>
                <Run Text=" Fail"/>
            </TextBlock>
            <TextBlock Text=" | " Opacity="0.5"/>
            <TextBlock Foreground="#E5A100"
                       AutomationProperties.Name="{Binding WarningCount, StringFormat='{}{0} warnings', Mode=OneWay}">
                <Run Text="{Binding WarningCount, Mode=OneWay}"/>
                <Run Text=" Warn"/>
            </TextBlock>
            <TextBlock Text=" | " Opacity="0.5"/>
            <TextBlock Foreground="#3DA63D"
                       AutomationProperties.Name="{Binding PassCount, StringFormat='{}{0} passed', Mode=OneWay}">
                <Run Text="{Binding PassCount, Mode=OneWay}"/>
                <Run Text=" Pass"/>
            </TextBlock>
        </StackPanel>

        <!-- Fix result review panel -->
        <Border Grid.Row="2" Margin="4,2,4,4" CornerRadius="4" Padding="8,6"
                Visibility="{Binding LastFixMessage, TargetNullValue=Collapsed, FallbackValue=Collapsed}"
                AutomationProperties.LiveSetting="Assertive">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="#1A4D8FD6"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding FixStatusLabel}" Value="Applied">
                            <Setter Property="Background" Value="#1A3DA63D"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding FixStatusLabel}" Value="Failed">
                            <Setter Property="Background" Value="#1AE04343"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel>
                <!-- Status badge + dismiss -->
                <DockPanel>
                    <Button DockPanel.Dock="Right" Content="&#xE711;" FontFamily="Segoe MDL2 Assets"
                            FontSize="10" Padding="4,2" Background="Transparent" BorderThickness="0"
                            Command="{Binding DismissFixMessageCommand}"
                            AutomationProperties.Name="Dismiss fix message"
                            ToolTip="Dismiss" VerticalAlignment="Top"/>
                    <TextBlock Text="{Binding FixStatusLabel}" FontWeight="SemiBold" FontSize="11"
                               VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#4D8FD6"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding FixStatusLabel}" Value="Applied">
                                        <Setter Property="Foreground" Value="#3DA63D"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding FixStatusLabel}" Value="Failed">
                                        <Setter Property="Foreground" Value="#E04343"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </DockPanel>

                <!-- Summary text -->
                <TextBlock Text="{Binding LastFixMessage}" TextWrapping="Wrap"
                           FontSize="11" Margin="0,4,0,0" Opacity="0.85"/>

                <!-- Before / After color swatches -->
                <StackPanel Orientation="Horizontal" Margin="0,6,0,0"
                            Visibility="{Binding HasColorSwatch, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="Before:" FontSize="10" Opacity="0.6" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <Border Width="40" Height="18" CornerRadius="2" BorderBrush="Gray" BorderThickness="1"
                            Background="{Binding OriginalColorHex, Converter={StaticResource HexToBrush}}"
                            AutomationProperties.Name="{Binding OriginalColorHex, StringFormat='Original color {0}'}"/>
                    <TextBlock Text="{Binding OriginalColorHex}" FontSize="10" Opacity="0.6"
                               VerticalAlignment="Center" Margin="4,0,12,0" FontFamily="Consolas"/>

                    <TextBlock Text="After:" FontSize="10" Opacity="0.6" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <Border Width="40" Height="18" CornerRadius="2" BorderBrush="Gray" BorderThickness="1"
                            Background="{Binding SuggestedColorHex, Converter={StaticResource HexToBrush}}"
                            AutomationProperties.Name="{Binding SuggestedColorHex, StringFormat='Suggested color {0}'}"/>
                    <TextBlock Text="{Binding SuggestedColorHex}" FontSize="10" Opacity="0.6"
                               VerticalAlignment="Center" Margin="4,0,0,0" FontFamily="Consolas"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <ListBox Grid.Row="1" ItemsSource="{Binding Findings}"
                 SelectedItem="{Binding SelectedFinding}"
                 Margin="4,0,4,4"
                 AutomationProperties.Name="{Binding PrincipleLabel, StringFormat='{}{0} findings list'}"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 KeyboardNavigation.TabNavigation="Continue"
                 x:Name="FindingsListBox">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="AutomationProperties.Name">
                        <Setter.Value>
                            <MultiBinding StringFormat="{}{0} {1}: {2}">
                                <Binding Path="Severity"/>
                                <Binding Path="Criterion.Id"/>
                                <Binding Path="Element"/>
                            </MultiBinding>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="AutomationProperties.HelpText" Value="{Binding Detail}"/>
                    <Setter Property="ToolTip" Value="Double-click or press Enter to view details"/>
                    <EventSetter Event="MouseDoubleClick" Handler="ListBoxItem_MouseDoubleClick"/>
                    <EventSetter Event="KeyDown" Handler="ListBoxItem_KeyDown"/>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="4,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Severity icon -->
                        <TextBlock Grid.Column="0"
                                   Text="{Binding Severity, Converter={StaticResource SeverityToIcon}}"
                                   Foreground="{Binding Severity, Converter={StaticResource SeverityToColor}}"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="16" VerticalAlignment="Top"/>

                        <!-- Finding details -->
                        <StackPanel Grid.Column="1">
                            <TextBlock FontWeight="Bold" TextWrapping="Wrap">
                                <Run Text="{Binding Criterion.Id, Mode=OneWay}"/>
                                <Run Text=" - "/>
                                <Run Text="{Binding Element, Mode=OneWay}"/>
                            </TextBlock>

                            <TextBlock Text="{Binding Detail}" TextWrapping="Wrap"
                                       Opacity="0.65" FontSize="11.5" Margin="0,2,0,0"/>

                            <!-- Color swatches if present -->
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0"
                                        Visibility="{Binding ForegroundColor, TargetNullValue=Collapsed, FallbackValue=Collapsed}"
                                        AutomationProperties.Name="{Binding ContrastRatio, StringFormat='Contrast ratio {0:F1} to 1'}">
                                <Border Width="30" Height="16" CornerRadius="2"
                                        Background="{Binding ForegroundColor, Converter={StaticResource ColorToBrush}}"
                                        BorderBrush="Gray" BorderThickness="1"
                                        AutomationProperties.Name="Foreground color swatch"/>
                                <TextBlock Text=" on " VerticalAlignment="Center" FontSize="10"
                                           Opacity="0.5"/>
                                <Border Width="30" Height="16" CornerRadius="2"
                                        Background="{Binding BackgroundColor, Converter={StaticResource ColorToBrush}}"
                                        BorderBrush="Gray" BorderThickness="1"
                                        AutomationProperties.Name="Background color swatch"/>
                                <TextBlock VerticalAlignment="Center" FontSize="10"
                                           Opacity="0.5" Margin="6,0,0,0">
                                    <Run Text="{Binding ContrastRatio, StringFormat='{}{0:F1}:1', Mode=OneWay}"/>
                                </TextBlock>
                            </StackPanel>

                            <!-- Remediation preview -->
                            <TextBlock Text="{Binding Remediation}" TextWrapping="Wrap"
                                       FontSize="11" Foreground="#4D8FD6" Margin="0,4,0,0"
                                       Visibility="{Binding Remediation, TargetNullValue=Collapsed, FallbackValue=Collapsed}"/>
                        </StackPanel>

                        <!-- Fix button — collapsed when no fix strategy is available -->
                        <Button Grid.Column="2" Content="Fix"
                                Command="{Binding DataContext.ApplyFixCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                CommandParameter="{Binding}"
                                AutomationProperties.Name="Apply fix for this finding"
                                ToolTip="Apply a fix for this finding"
                                VerticalAlignment="Top" Margin="4,0,0,0"
                                Padding="8,2" MinWidth="40" FontSize="11">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Style.Triggers>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>
