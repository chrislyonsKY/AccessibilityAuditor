<controls:ProWindow x:Class="AccessibilityAuditor.Windows.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:ArcGIS.Desktop.Framework.Controls;assembly=ArcGIS.Desktop.Framework"
    Title="Accessibility Auditor - Settings"
    Height="340" Width="460"
    MinHeight="300" MinWidth="400"
    WindowStartupLocation="CenterOwner"
    ShowInTaskbar="False"
    AutomationProperties.Name="Accessibility Auditor Settings"
    FocusManager.FocusedElement="{Binding ElementName=IncludePassCheck}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Audit Settings" FontWeight="Bold" FontSize="14" Margin="0,0,0,12"/>

            <CheckBox Content="Include passing findings in results"
                      IsChecked="{Binding IncludePassFindings}"
                      Margin="0,0,0,8"
                      x:Name="IncludePassCheck"
                      AutomationProperties.Name="Include pass findings in results"
                      ToolTip="When checked, passing findings are shown alongside failures and warnings"/>

            <CheckBox Content="Evaluate colorblind safety"
                      IsChecked="{Binding CheckColorBlindSafety}"
                      Margin="0,0,0,8"
                      AutomationProperties.Name="Evaluate colorblind safety"
                      ToolTip="When checked, the audit evaluates whether map colors remain distinguishable under color vision deficiency"/>

            <Grid Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Contrast warning margin:"
                           VerticalAlignment="Center" Margin="0,0,8,0"
                           x:Name="MarginLabel"/>
                <TextBox Grid.Column="1" Text="{Binding ContrastWarningMargin, StringFormat=F1}" Width="50"
                         AutomationProperties.LabeledBy="{Binding ElementName=MarginLabel}"
                         AutomationProperties.Name="Contrast warning margin"
                         ToolTip="Contrast ratio margin above the WCAG threshold that triggers a warning"/>
                <Border Grid.Column="2" Width="16" Height="16" CornerRadius="8"
                        BorderBrush="{Binding Foreground, ElementName=MarginLabel}" BorderThickness="1"
                        VerticalAlignment="Center" Margin="6,0,0,0"
                        Cursor="Help"
                        AutomationProperties.Name="Warning margin info"
                        AutomationProperties.HelpText="Colors that barely pass the contrast threshold within this margin are flagged as warnings instead of passes. For example, with a margin of 0.5, a text contrast ratio of 4.7 to 1 would be flagged as a warning because it is within 0.5 of the 4.5 to 1 minimum."
                        ToolTip="Colors that barely pass the contrast threshold (within this margin) are flagged as warnings instead of passes.&#x0a;&#x0a;Example: With a margin of 0.5, a contrast ratio of 4.7:1 is flagged as a warning because it is within 0.5 of the 4.5:1 minimum.">
                    <TextBlock Text="i" FontSize="10" FontWeight="Bold" FontStyle="Italic"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               IsHitTestVisible="False"/>
                </Border>
            </Grid>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="OK" Width="80" Margin="0,0,8,0" IsDefault="True"
                    Click="OkButton_Click"
                    AutomationProperties.Name="Save settings and close"
                    ToolTip="Save settings and close"/>
            <Button Content="Cancel" Width="80" IsCancel="True"
                    AutomationProperties.Name="Discard changes and close"
                    ToolTip="Discard changes and close"/>
        </StackPanel>
    </Grid>
</controls:ProWindow>
