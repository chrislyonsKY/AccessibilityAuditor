        <controls:ProWindow x:Class="AccessibilityAuditor.Windows.ColorSimulationWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:ArcGIS.Desktop.Framework.Controls;assembly=ArcGIS.Desktop.Framework"
    Title="{Binding WindowTitle}"
    Height="580" Width="780"
    MinHeight="440" MinWidth="620"
    WindowStartupLocation="CenterOwner"
    ShowInTaskbar="False"
    AutomationProperties.Name="{Binding WindowTitle}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
        <StackPanel>

            <!-- Column headers -->
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Original" FontWeight="Bold" HorizontalAlignment="Center"
                           AutomationProperties.Name="Original colors column"/>
                <TextBlock Grid.Column="1" Text="Protanopia" FontWeight="Bold" HorizontalAlignment="Center"
                           AutomationProperties.Name="Protanopia simulation column — red-blind"/>
                <TextBlock Grid.Column="2" Text="Deuteranopia" FontWeight="Bold" HorizontalAlignment="Center"
                           AutomationProperties.Name="Deuteranopia simulation column — green-blind"/>
                <TextBlock Grid.Column="3" Text="Tritanopia" FontWeight="Bold" HorizontalAlignment="Center"
                           AutomationProperties.Name="Tritanopia simulation column — blue-blind"/>
            </Grid>

            <!-- Palette grid: four ItemsControls side by side -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Original -->
                <ItemsControl Grid.Column="0" ItemsSource="{Binding OriginalSwatches}" Margin="4"
                              AutomationProperties.Name="Original color palette">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="2"
                                        AutomationProperties.Name="{Binding Label}">
                                <Border Width="32" Height="20" CornerRadius="2"
                                        Background="{Binding Brush}"
                                        BorderBrush="Gray" BorderThickness="1"
                                        ToolTip="{Binding Label}"
                                        AutomationProperties.Name="{Binding Hex}"/>
                                <TextBlock Text="{Binding Label}" FontSize="10" Margin="4,0,0,0"
                                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                           MaxWidth="120"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Protanopia -->
                <ItemsControl Grid.Column="1" ItemsSource="{Binding ProtanSwatches}" Margin="4"
                              AutomationProperties.Name="Protanopia simulated palette">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="2"
                                        AutomationProperties.Name="{Binding Label, StringFormat='Protanopia: {0}'}">
                                <Border Width="32" Height="20" CornerRadius="2"
                                        Background="{Binding Brush}"
                                        BorderBrush="Gray" BorderThickness="1"
                                        ToolTip="{Binding Label}"
                                        AutomationProperties.Name="{Binding Hex}"/>
                                <TextBlock Text="{Binding Hex}" FontSize="10" Margin="4,0,0,0"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Deuteranopia -->
                <ItemsControl Grid.Column="2" ItemsSource="{Binding DeuteranSwatches}" Margin="4"
                              AutomationProperties.Name="Deuteranopia simulated palette">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="2"
                                        AutomationProperties.Name="{Binding Label, StringFormat='Deuteranopia: {0}'}">
                                <Border Width="32" Height="20" CornerRadius="2"
                                        Background="{Binding Brush}"
                                        BorderBrush="Gray" BorderThickness="1"
                                        ToolTip="{Binding Label}"
                                        AutomationProperties.Name="{Binding Hex}"/>
                                <TextBlock Text="{Binding Hex}" FontSize="10" Margin="4,0,0,0"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Tritanopia -->
                <ItemsControl Grid.Column="3" ItemsSource="{Binding TritanSwatches}" Margin="4"
                              AutomationProperties.Name="Tritanopia simulated palette">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="2"
                                        AutomationProperties.Name="{Binding Label, StringFormat='Tritanopia: {0}'}">
                                <Border Width="32" Height="20" CornerRadius="2"
                                        Background="{Binding Brush}"
                                        BorderBrush="Gray" BorderThickness="1"
                                        ToolTip="{Binding Label}"
                                        AutomationProperties.Name="{Binding Hex}"/>
                                <TextBlock Text="{Binding Hex}" FontSize="10" Margin="4,0,0,0"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>

            <!-- Separator -->
            <Separator Margin="0,12,0,8"/>

            <!-- Distinguishability issues -->
            <TextBlock Text="{Binding IssuesSummary}" FontWeight="SemiBold" TextWrapping="Wrap"
                       Margin="0,0,0,4"
                       AutomationProperties.Name="{Binding IssuesSummary}"/>

            <ItemsControl ItemsSource="{Binding Issues}" Margin="0,4,0,0"
                          AutomationProperties.Name="Colorblind distinguishability issues">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="4,2"
                                    AutomationProperties.Name="{Binding Description}">
                            <Border Width="24" Height="16" CornerRadius="2"
                                    Background="{Binding Brush1}"
                                    BorderBrush="Gray" BorderThickness="1"
                                    ToolTip="{Binding Hex1}"
                                    AutomationProperties.Name="{Binding Hex1, StringFormat='First color {0}'}"/>
                            <TextBlock Text=" &#x2194; " VerticalAlignment="Center" Foreground="Gray"/>
                            <Border Width="24" Height="16" CornerRadius="2"
                                    Background="{Binding Brush2}"
                                    BorderBrush="Gray" BorderThickness="1"
                                    ToolTip="{Binding Hex2}"
                                    AutomationProperties.Name="{Binding Hex2, StringFormat='Second color {0}'}"/>
                            <TextBlock Text="{Binding Description}" Margin="8,0,0,0"
                                       VerticalAlignment="Center" FontSize="11" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Contrast loss section -->
            <Separator Margin="0,12,0,8"/>

            <TextBlock Text="{Binding ContrastLossSummary}" FontWeight="SemiBold" TextWrapping="Wrap"
                       Margin="0,0,0,4"
                       AutomationProperties.Name="{Binding ContrastLossSummary}"/>

            <ItemsControl ItemsSource="{Binding ContrastLosses}" Margin="0,4,0,0"
                          AutomationProperties.Name="Simulated contrast losses">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="4,2"
                                    AutomationProperties.Name="{Binding Description}">
                            <Border Width="24" Height="16" CornerRadius="2"
                                    Background="{Binding Brush}"
                                    BorderBrush="Gray" BorderThickness="1"
                                    AutomationProperties.Name="{Binding Label}"/>
                            <TextBlock Text="{Binding Description}" Margin="8,0,0,0"
                                       VerticalAlignment="Center" FontSize="11" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </ScrollViewer>
</controls:ProWindow>
